fun caesar[18,5,18,10] : (s : std/core/types/string) -> std/core/types/string;
// The letter frequency table for English
val english[23,5,23,11] : (std/core/types/list :: V -> V)<std/core/types/float64>;
// Small helper functions
fun percent[29,5,29,11] : (n : std/core/types/int, m : std/core/types/int) -> std/core/types/float64;
