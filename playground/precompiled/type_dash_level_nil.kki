//.inline-section
inline fun t-nil/@copy // inline size: 0
  = fn(@this: t-nil){
    type-level/nil/TNil;
  };
inline fun append // inline size: 0
  = forall<a> fn(@x@_wildcard-x15_16: t-nil, r: a){
    r;
  };
inline fun (++) // inline size: 0
  = forall<a> fn(@x@_wildcard-x17_14: t-nil, r: a){
    r;
  };
