//------------------------------
//#kki: inline definitions
 
//.inline-section
fun consrev // inline size: 4
  = fn(xs: (std/core/types/list :: V -> V)<std/core/types/char>, xss: (std/core/types/list :: V -> V)<std/core/types/string>){
    match (xs) {
      ((std/core/types/Nil() : (std/core/types/list :: V -> V)<std/core/types/char> ) as @pat: ((std/core/types/list :: V -> V)<std/core/types/char>))
         -> xss;
      (@pat@0: ((std/core/types/list :: V -> V)<std/core/types/char>))
         -> std/core/types/Cons<std/core/types/string>((std/core/string/#listchar/string((std/core/list/reverse-acc<std/core/types/char>((std/core/types/Nil<std/core/types/char>), xs)))), xss);
    };
  };
fun graphemes // inline size: 3
  = fn(s: std/core/types/string){
    std/text/unicode/join-combining((std/core/string/list((std/text/unicode/normalizex(s, "NFC")))), (std/core/types/@NoOptArg<(std/core/types/list :: V -> V)<std/core/types/char>>), (std/core/types/@NoOptArg<(std/core/types/list :: V -> V)<grapheme>>));
  };
inline borrow "^" fip fun is-nfc // inline size: 1
  = fn(normalization: normalization){
    match (normalization) {
      ((std/text/unicode/NFC() : normalization ) as @pat: normalization)
         -> std/core/types/True;
      (@pat@0: normalization)
         -> std/core/types/False;
    };
  };
inline borrow "^" fip fun is-nfd // inline size: 1
  = fn(normalization: normalization){
    match (normalization) {
      ((std/text/unicode/NFD() : normalization ) as @pat: normalization)
         -> std/core/types/True;
      (@pat@0: normalization)
         -> std/core/types/False;
    };
  };
inline borrow "^" fip fun is-nfkc // inline size: 1
  = fn(normalization: normalization){
    match (normalization) {
      ((std/text/unicode/NFKC() : normalization ) as @pat: normalization)
         -> std/core/types/True;
      (@pat@0: normalization)
         -> std/core/types/False;
    };
  };
inline borrow "^" fip fun is-nfkd // inline size: 1
  = fn(normalization: normalization){
    match (normalization) {
      ((std/text/unicode/NFKD() : normalization ) as @pat: normalization)
         -> std/core/types/True;
      (@pat@0: normalization)
         -> std/core/types/False;
    };
  };
fun build-rtree // inline size: 1
  = fn(xs: (std/core/types/list :: V -> V)<rtree>){
    std/text/unicode/combine(xs);
  };
fun single // inline size: 1
  = fn(lo: std/core/types/int, hi: std/core/types/int){
    std/text/unicode/Bin(lo, hi, std/text/unicode/Tip, std/text/unicode/Tip);
  };
inline borrow "^" fip fun is-tip // inline size: 1
  = fn(rtree: rtree){
    match (rtree) {
      ((std/text/unicode/Tip() : rtree ) as @pat: rtree)
         -> std/core/types/True;
      ((@skip std/text/unicode/Bin((@pat@1: std/core/types/int) : std/core/types/int, (@pat@2: std/core/types/int) : std/core/types/int, (@pat@3: rtree) : rtree, (@pat@4: rtree) : rtree) : rtree ) as @pat@0: rtree)
         -> std/core/types/False;
    };
  };
inline borrow "^" fip fun is-bin // inline size: 1
  = fn(rtree: rtree){
    match (rtree) {
      ((std/text/unicode/Bin((@pat@0: std/core/types/int) : std/core/types/int, (@pat@1: std/core/types/int) : std/core/types/int, (@pat@2: rtree) : rtree, (@pat@3: rtree) : rtree) : rtree ) as @pat: rtree)
         -> std/core/types/True;
      ((@skip std/text/unicode/Tip() : rtree ) as @pat@4: rtree)
         -> std/core/types/False;
    };
  };