// Declare an effect `:input` with a single operation `ask`.
// We use `fun` instead of general `ctl` to ensure that all handlers
// will always resume (at most once) with the result.
recursive effect type ask[20,1,20,25] <(e :: E),a> :: (E, V) -> V {
  con @Hnd-ask[20,1,20,13](@cfc: std/core/types/int, @fun-ask: (std/core/hnd/clause0 :: (V, (E, V) -> V, E, V) -> V)<std/core/types/string,(ask :: (E, V) -> V),(e :: E),a>){0,2,8} : forall<(e :: E),a> (std/core/types/int, (std/core/hnd/clause0 :: (V, (E, V) -> V, E, V) -> V)<std/core/types/string,(ask :: (E, V) -> V),(e :: E),a>) -> (ask :: (E, V) -> V)<(e :: E),a> = 1;
};
recursive effect type flip[141,1,141,24] <(e :: E),a> :: (E, V) -> V {
  con @Hnd-flip[141,1,141,14](@cfc: std/core/types/int, @ctl-flip: (std/core/hnd/clause0 :: (V, (E, V) -> V, E, V) -> V)<std/core/types/bool,(flip :: (E, V) -> V),(e :: E),a>){0,2,8} : forall<(e :: E),a> (std/core/types/int, (std/core/hnd/clause0 :: (V, (E, V) -> V, E, V) -> V)<std/core/types/bool,(flip :: (E, V) -> V),(e :: E),a>) -> (flip :: (E, V) -> V)<(e :: E),a> = 1;
};
