// Now we use general ctl `ctl` as we want to enable breaking
// the interaction (and thus not resume). Equivalent to:
// ````
// effect yield<a>
//   ctl yield( item : a ) : ()
// ````
recursive effect type yield[111,1,111,36] <a,(e :: E),b> :: (V, E, V) -> V {
  con @Hnd-yield[111,1,111,18](@cfc: std/core/types/int, @ctl-yield: (std/core/hnd/clause1 :: (V, V, (E, V) -> V, E, V) -> V)<a,(),(yield :: (V, E, V) -> V)<a>,(e :: E),b>){0,2,8} : forall<a,(e :: E),b> (std/core/types/int, (std/core/hnd/clause1 :: (V, V, (E, V) -> V, E, V) -> V)<a,(),(yield :: (V, E, V) -> V)<a>,(e :: E),b>) -> (yield :: (V, E, V) -> V)<a,(e :: E),b> = 1;
};
 
