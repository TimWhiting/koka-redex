//.inline-section
fun twice // inline size: 2
  = forall<a,(e :: E)> fn<(e :: E)>(f: () -> (e :: E) a){
    val _[21,3,21,5] : a
          = f();
    f();
  };
fun example1 // inline size: 4
  = fn<<(std/core/console/console :: X)>>(){
    val _@0[21,3,21,5] : ()
      = std/core/console/printsln("hi");
    val _[21,3,21,5] : ()
      = std/core/console/printsln("hi");
    val _@0@0[21,3,21,5] : ()
      = std/core/console/printsln("hi");
    std/core/console/printsln("hi");
  };
fun example1-expanded // inline size: 4
  = fn<<(std/core/console/console :: X)>>(){
    val _@0[21,3,21,5] : ()
      = std/core/console/printsln("hi");
    val _[21,3,21,5] : ()
      = std/core/console/printsln("hi");
    val _@0@0[21,3,21,5] : ()
      = std/core/console/printsln("hi");
    std/core/console/printsln("hi");
  };
fun example1-fully-expanded // inline size: 4
  = fn<<(std/core/console/console :: X)>>(){
    val _@0[21,3,21,5] : ()
