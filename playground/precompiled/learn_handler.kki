fun ask/@cfc[72,1,72,13] : forall<(e :: E),a> (^ ask : (ask :: (E, V) -> V)<(e :: E),a>) -> std/core/types/int;
// runtime tag for the effect `:ask`
val ask/@tag[72,1,72,13] : (std/core/hnd/htag :: ((E, V) -> V) -> V)<(ask :: (E, V) -> V)>;
// handler for the effect `:ask`
fun ask/@handle[72,12,72,13] : forall<a,(e :: E),b> (hnd : (ask :: (E, V) -> V)<(e :: E),b>, ret : (res : a) -> (e :: E) b, action : () -> <(std/core/types/handled1 :: ((E, V) -> V) -> X)<(ask :: (E, V) -> V)>|(e :: E)> a) -> (e :: E) b;
// Call the `val ask` operation of the effect `:ask`
val ask[72,12,72,14] : (std/core/types/@valueop :: (E, V) -> V)<<(std/core/types/handled1 :: ((E, V) -> V) -> X)<(ask :: (E, V) -> V)>>,std/core/types/int>;
// Dynamic binding with static typing!
fun print-ask[75,5,75,13] : () -> <(std/core/types/handled1 :: ((E, V) -> V) -> X)<(ask :: (E, V) -> V)>,(std/core/console/console :: X)> ();
// Using different handlers for each invocation
fun example5[80,5,80,12] : () -> <(std/core/console/console :: X)> ();
pub fun main[84,9,84,12] : () -> <(std/core/console/console :: X)> ();
 
