//------------------------------
//#kki: type declarations
 
// Grapheme's are an alias for `:string`.
// Each grapheme is a self-contained symbol consisting of
// a unicode character followed by combining characters and/or
//  combining marks.
pub alias grapheme[20,1,20,27] = std/core/types/string = 1;
// Type of unicode [normalization](https://www.unicode.org/reports/tr15)
pub value{1,0,1} type normalization[66,1,75,1] {
  // Canonical composition (default). Use composed characters when possible.
  pub con NFC[68,7,68,9]{0,0,0} : normalization = 1;
  // Canonical decomposition.
  pub con NFD[70,7,70,9]{0,0,0} : normalization = 2;
  // Compatibility composition.
  pub con NFKC[72,7,72,10]{0,0,0} : normalization = 3;
  // Compatibility decomposition.
  pub con NFKD[74,7,74,10]{0,0,0} : normalization = 4;
};
// Type of range trees
recursive type rtree[201,1,204,1] {
  con Tip[202,3,202,5]{0,0,0} : rtree = 1;
  con Bin[203,3,203,5](lo: std/core/types/int, hi: std/core/types/int, left: rtree, right: rtree){0,4,8} : (lo : std/core/types/int, hi : std/core/types/int, left : rtree, right : rtree) -> rtree = 2;
};
 
//------------------------------
//#kki: declarations
 
// Is this a combining character?
pub fun is-combining[32,9,32,20] : (c : std/core/types/char) -> std/core/types/bool;
fun consrev[50,5,50,11] : (xs : (std/core/types/list :: V -> V)<std/core/types/char>, xss : (std/core/types/list :: V -> V)<std/core/types/string>) -> (std/core/types/list :: V -> V)<std/core/types/string>;
// Join combining characters with their base into a grapheme.
fun join-combining[42,5,42,18] : (cs : (std/core/types/list :: V -> V)<std/core/types/char>, comb : (std/core/types/@optional :: V -> V)<(std/core/types/list :: V -> V)<std/core/types/char>>, acc : (std/core/types/@optional :: V -> V)<(std/core/types/list :: V -> V)<grapheme>>) -> (std/core/types/list :: V -> V)<grapheme>;
fun normalizex[78,8,78,17] : (s : std/core/types/string, norm : std/core/types/string) -> std/core/types/string;
// Normalize a unicode string. If no normalization form is given, `NFC` is used.
pub fun normalize[85,9,85,17] : (s : std/core/types/string, norm : (std/core/types/@optional :: V -> V)<normalization>) -> std/core/types/string;
// Convert a string to a list of graphemes.
// Each grapheme will be in `NFC` normalized form.
pub fun graphemes[56,9,56,17] : (s : std/core/types/string) -> (std/core/types/list :: V -> V)<grapheme>;
// Automatically generated. Tests for the `NFC` constructor of the `:normalization` type.
pub fip fun is-nfc[68,7,68,9] : (^ normalization : normalization) -> std/core/types/bool;
// Automatically generated. Tests for the `NFD` constructor of the `:normalization` type.
pub fip fun is-nfd[70,7,70,9] : (^ normalization : normalization) -> std/core/types/bool;
// Automatically generated. Tests for the `NFKC` constructor of the `:normalization` type.
pub fip fun is-nfkc[72,7,72,10] : (^ normalization : normalization) -> std/core/types/bool;
// Automatically generated. Tests for the `NFKD` constructor of the `:normalization` type.
pub fip fun is-nfkd[74,7,74,10] : (^ normalization : normalization) -> std/core/types/bool;
fun bin[226,5,226,7] : (x : rtree, y : rtree) -> rtree;
fun @trmc-combine-pairs[242,5,242,17] : (xs : (std/core/types/list :: V -> V)<rtree>, @acc : (std/core/types/ctx :: V -> V)<(std/core/types/list :: V -> V)<rtree>>) -> (std/core/types/list :: V -> V)<rtree>;
fun combine-pairs[242,5,242,17] : (xs : (std/core/types/list :: V -> V)<rtree>) -> (std/core/types/list :: V -> V)<rtree>;
fun combine[234,5,234,11] : (xs : (std/core/types/list :: V -> V)<rtree>) -> rtree;
fun build-rtree[218,5,218,15] : (xs : (std/core/types/list :: V -> V)<rtree>) -> rtree;
fun single[222,5,222,10] : (lo : std/core/types/int, hi : std/core/types/int) -> rtree;
// These characters are considered wide, i.e. 2 columns wide.
val asian-wide[122,5,122,14] : (std/core/delayed/delayed :: (E, V) -> V)<(std/core/types/total :: E),rtree>;
// These characters have zero width
val zero-widths[141,5,141,15] : (std/core/delayed/delayed :: (E, V) -> V)<(std/core/types/total :: E),rtree>;
// Automatically generated. Tests for the `Tip` constructor of the `:rtree` type.
fip fun is-tip[202,3,202,5] : (^ rtree : rtree) -> std/core/types/bool;
// Automatically generated. Tests for the `Bin` constructor of the `:rtree` type.
fip fun is-bin[203,3,203,5] : (^ rtree : rtree) -> std/core/types/bool;
// Is a value contained in a range tree?
fun contains[207,5,207,12] : (t : rtree, i : std/core/types/int) -> std/core/types/bool;
// Return the column-width of a unicode character.
// Equivalent to ``wcwidth``
pub fun char/width[102,9,102,18] : (c : std/core/types/char) -> std/core/types/int;
// Return the total column-width of a string.
pub fun string/width[109,9,109,20] : (s : std/core/types/string) -> std/core/types/int;
 
