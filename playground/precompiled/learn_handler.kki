// A dynamically bound value `ask`
recursive linear effect type ask[72,1,72,20] <(e :: E),a> :: (E, V) -> V {
  con @Hnd-ask[72,1,72,13](@cfc: std/core/types/int, @val-ask: (std/core/hnd/clause0 :: (V, (E, V) -> V, E, V) -> V)<std/core/types/int,(ask :: (E, V) -> V),(e :: E),a>){0,2,8} : forall<(e :: E),a> (std/core/types/int, (std/core/hnd/clause0 :: (V, (E, V) -> V, E, V) -> V)<std/core/types/int,(ask :: (E, V) -> V),(e :: E),a>) -> (ask :: (E, V) -> V)<(e :: E),a> = 1;
};
// An effect declaration of type `:example` with
// a single (control) operation `raise`.
recursive effect type example[11,1,13,30] <(e :: E),a> :: (E, V) -> V {
  con @Hnd-example[11,1,11,14](@cfc: std/core/types/int, @ctl-raise: forall<b> (std/core/hnd/clause1 :: (V, V, (E, V) -> V, E, V) -> V)<std/core/types/string,b,(example :: (E, V) -> V),(e :: E),a>){0,2,8} : forall<(e :: E),a> (std/core/types/int, forall<b> (std/core/hnd/clause1 :: (V, V, (E, V) -> V, E, V) -> V)<std/core/types/string,b,(example :: (E, V) -> V),(e :: E),a>) -> (example :: (E, V) -> V)<(e :: E),a> = 1;
};
 
