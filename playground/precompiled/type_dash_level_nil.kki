pub fun append[15,9,15,14] : forall<a> (@x@_wildcard-x15_16 : t-nil, r : a) -> a;
pub fun (++)[17,9,17,12] : forall<a> (@x@_wildcard-x17_14 : t-nil, r : a) -> a;
