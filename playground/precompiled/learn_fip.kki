//.inline-section
recursive specialize "__*" borrow "__^" fip(1) fun insert-order // inline size: 10
  = forall<a> fn(t: (tree :: V -> V)<a>, k: a, @implicit/order2: (a, a) -> (std/core/types/order2 :: V -> V)<a>){
    (match (t) {
      ((learn/fip/Bin((l: (tree :: V -> V)<a>) : (tree :: V -> V)<a>, (x: a) : a, (r: (tree :: V -> V)<a>) : (tree :: V -> V)<a>) : (tree :: V -> V)<a> ) as @pat: ((tree :: V -> V)<a>))
         -> (match ((@implicit/order2(x, k))) {
          ((std/core/types/Eq2((kx: a) : a) : (std/core/types/order2 :: V -> V)<a> ) as @pat@0: ((std/core/types/order2 :: V -> V)<a>))
             -> learn/fip/Bin<a>(l, kx, r);
          ((std/core/types/Lt2((kx@0: a) : a, (kk: a) : a) : (std/core/types/order2 :: V -> V)<a> ) as @pat@1: ((std/core/types/order2 :: V -> V)<a>))
             -> learn/fip/Bin<a>(l, kx@0, (learn/fip/insert-order<a>(r, kk, @implicit/order2)));
          ((@skip std/core/types/Gt2((kk@0: a) : a, (kx@1: a) : a) : (std/core/types/order2 :: V -> V)<a> ) as @pat@2: ((std/core/types/order2 :: V -> V)<a>))
             -> learn/fip/Bin<a>((learn/fip/insert-order<a>(l, kk@0, @implicit/order2)), kx@1, r);
        });
      ((@skip learn/fip/Tip() : (tree :: V -> V)<a> ) as @pat@3: ((tree :: V -> V)<a>))
         -> learn/fip/Bin<a>((learn/fip/Tip<a>), k, (learn/fip/Tip<a>));
    });
  };
recursive specialize "__*" borrow "__^" fun insert-poly // inline size: 12
  = forall<a> fn(t: (tree :: V -> V)<a>, k: a, @implicit/cmp: (a, a) -> std/core/types/order){
    (match (t) {
      ((learn/fip/Bin((l: (tree :: V -> V)<a>) : (tree :: V -> V)<a>, (x: a) : a, (r: (tree :: V -> V)<a>) : (tree :: V -> V)<a>) : (tree :: V -> V)<a> ) as @pat: ((tree :: V -> V)<a>))
         -> (match ((@implicit/cmp(x, k))) {
          ((std/core/types/Eq() : std/core/types/order ) as @pat@0: std/core/types/order)
             -> learn/fip/Bin<a>(l, k, r);
          (@pat@0@0: std/core/types/order)
             -> (match ((std/core/order/(==)((@implicit/cmp(x, k)), std/core/types/Lt))) {
              ((std/core/types/True() : std/core/types/bool ) as @pat@2: std/core/types/bool)
                 -> learn/fip/Bin<a>(l, x, (learn/fip/insert-poly<a>(r, k, @implicit/cmp)));
              ((@skip std/core/types/False() : std/core/types/bool ) as @pat@3: std/core/types/bool)
                 -> learn/fip/Bin<a>((learn/fip/insert-poly<a>(l, k, @implicit/cmp)), x, r);
            });
        });
      ((@skip learn/fip/Tip() : (tree :: V -> V)<a> ) as @pat@4: ((tree :: V -> V)<a>))
         -> learn/fip/Bin<a>((learn/fip/Tip<a>), k, (learn/fip/Tip<a>));
    });
  };
specialize "_*" borrow "_^" fun tree // inline size: 1
  = forall<a> fn(elems: (std/core/types/list :: V -> V)<a>, @implicit/order2: (a, a) -> (std/core/types/order2 :: V -> V)<a>){
    std/core/list/foldl<a,(tree :: V -> V)<a>,(std/core/types/total :: E)>(elems, (learn/fip/Tip<a>), (fn(t: (tree :: V -> V)<a>, i: a){
        (learn/fip/insert-order<a>(t, i, @implicit/order2));
      }));
  };
fip fun rev // inline size: 1
  = forall<a> fn(xs: (std/core/types/list :: V -> V)<a>){
    learn/fip/rev-acc<a>(xs, (std/core/types/Nil<a>));
  };
fun example-persistent // inline size: 3
  = fn(){
    val xs[52,7,52,8] : (std/core/types/list :: V -> V)<std/core/types/int>
      = std/core/list/#range/list(1, 5);
    val ys@10004[1,0,1,0] : (std/core/types/list :: V -> V)<std/core/types/int>
      = learn/fip/rev-acc<std/core/types/int>(xs, (std/core/types/Nil<std/core/types/int>));
    std/core/list/append<std/core/types/int>(xs, ys@10004);
  };
inline borrow "^" fip fun is-bin // inline size: 1
  = forall<a> fn(tree@0: (tree :: V -> V)<a>){
    (match (tree@0) {
      ((learn/fip/Bin((@pat@0: (tree :: V -> V)<a>) : (tree :: V -> V)<a>, (@pat@1: a) : a, (@pat@2: (tree :: V -> V)<a>) : (tree :: V -> V)<a>) : (tree :: V -> V)<a> ) as @pat: ((tree :: V -> V)<a>))
