      val iev@3282 : hdiv<h,std/data/rb-map/rbmap<b,a>,<div,exn|e>>;
      val iev@3385 : hdiv<h,std/data/rb-map/rbmap<a,list<(b) -> <(pure == 1 <exn,div>),local<h>|e> ()>>,<div,exn|e>>;
      local-var((@open(empty)()), (fn(cache){
          ((fn(@action){
            (fn(x){
              local-get(cache, iev@1615);
            })((@action()));
          })((fn(){
            (local-var((@open(empty)()), (fn(deps){
                ((fn(@action){
                  cache/@handle((@Hnd-cache(3, (@open(clause-tail2)((fn(key, change){
                        (match ((lookup((local-get(cache, iev@1806)), key, (@open(?order2))))) {
                          (Just((r')) : maybe<a> )
                             -> (match ((@open(change-lattice/join)(r', change))) {
                              (@skip Tuple2((changed), (r'')) : (bool, a) )
                                 -> (match (changed) {
                                  (True() : bool )
                                     -> val _ : ()
                                              = local-set(cache, (set((local-get(cache, iev@2001)), key, r'', (@open(?order2)))));
                                    update((local-get(deps, iev@2054)), key, change, (@open(?order2)));
                                  (@skip False() : bool )
                                     -> Unit;
                                });
                            });
                          (@skip Nothing() : (maybe<a>) )
                             -> val _ : ()
                                      = local-set(cache, (set((local-get(cache, iev@2260)), key, (@open(tuple2/snd)((@open(change-lattice/join)(change-lattice/bottom, change)))), (@open(?order2)))));
                            update((local-get(deps, iev@2366)), key, change, (@open(?order2)));
                        });
                      }))), (@open(clause-control1)((fn(key, resume){
                        val _ : ()
                              = (match ((lookup((local-get(deps, iev@2510)), key, (@open(?order2))))) {
                                (Just((resumes)) : maybe<list<(a) -> <(pure == 1 <exn,div>),local<h>|e> ()>> )
                                   -> val ress : list<(a) -> <div,exn,local<h>|e> ()>
                                            = Cons(resume, resumes);
                                  local-set(deps, (set((local-get(deps, iev@2689)), key, ress, (@open(?order2)))));
                                _
                                   -> @open(error-pattern)(\"std/fixpoint/fixpoint-memo(46, 7)\", \"_\");
                              });
                        (match ((lookup((local-get(cache, iev@2757)), key, (@open(?order2))))) {
                          (Just((r)) : maybe<a> )
                             -> foreach((@open(change-lattice/changes)(r)), resume);
                          _
                             -> @open(error-pattern)(\"std/fixpoint/fixpoint-memo(50, 7)\", \"cache\");
                        });
                      }))), (forall<a> @open(clause-control1)((fn(ss, resume){
                        (foreach(ss, resume));
                      }))), (@open(clause-tail1)((fn(key){
                        (match ((match ((contains((local-get(cache, iev@2992)), key, (@open(?order2))))) {
                          (True() : bool )
                             -> True;
                          _
                             -> contains((local-get(deps, iev@3116)), key, (@open(?order2)));
                        })) {
                          (True() : bool )
                             -> True;
                          (@skip False() : bool )
                             -> val _ : ();
                                val _ : ();
                            False;
                        });
                      }))), (forall<a> @open(clause-never0)((fn(){
                        Unit;
                      }))))), (fn(x){
                      Unit;
                    }), @action);
                })((fn(){
                  ((fn(){
                    @mask-builtin((fn(){
                      (comp());
                    }));
                  })());
                })));
              })));
          })));
        }));
    }));
}<<call{LetBody(cache(@arg-x231, @arg-x232, @arg-x233, @arg-x234, @arg-x235)), .}:::Top>>

