// select `raise` operation out of effect `:example`
fun raise/@select[13,7,13,30] : forall<a,(e :: E),b> (^ hnd : (example :: (E, V) -> V)<(e :: E),b>) -> (std/core/hnd/clause1 :: (V, V, (E, V) -> V, E, V) -> V)<std/core/types/string,a,(example :: (E, V) -> V),(e :: E),b>;
// raise with a message

// Call the `ctl raise` operation of the effect `:example`
fun raise[13,7,13,11] : forall<a> (msg : std/core/types/string) -> <(std/core/types/handled :: ((E, V) -> V) -> X)<(example :: (E, V) -> V)>> a;
// Functions can use abstract operations like `raise`,
// but it is reflected in the effect type (`:example`).
// Such function requires the effect to be handled at some point.
fun foo[18,5,18,7] : (pred : std/core/types/bool) -> <(std/core/types/handled :: ((E, V) -> V) -> X)<(example :: (E, V) -> V)>> std/core/types/int;
// The basic `handler` expression takes a block
// of operation clauses and returns a handler function
// that function takes a unit-function `action`
// that is run under the handler.
fun example1[26,5,26,12] : () -> <(std/core/console/console :: X)> std/core/types/int;
// The `with` statement (see `learn/with`) can help to
// specify the previous handler more concisely as:
fun example2[34,5,34,12] : () -> <(std/core/console/console :: X)> std/core/types/int;
// If there is only one operation, we can shorten this further as:
fun example3[41,5,41,12] : () -> <(std/core/console/console :: X)> std/core/types/int;
// Mark `:raise` as `final` since it never resumes to the call-site
fun example4[66,5,66,12] : () -> <(std/core/console/console :: X)> std/core/types/int;
// select `@val-ask` operation out of effect `:ask`
fun @val-ask/@select[72,12,72,20] : forall<(e :: E),a> (^ hnd : (ask :: (E, V) -> V)<(e :: E),a>) -> (std/core/hnd/clause0 :: (V, (E, V) -> V, E, V) -> V)<std/core/types/int,(ask :: (E, V) -> V),(e :: E),a>;
// Call the `val ask` operation of the effect `:ask`
fun @val-ask[72,12,72,14] : () -> <(std/core/types/handled1 :: ((E, V) -> V) -> X)<(ask :: (E, V) -> V)>> std/core/types/int;
// Automatically generated. Retrieves the `@val-ask` constructor field of the `:ask` type.
fun ask/@val-ask[72,12,72,20] : forall<(e :: E),a> (^ ask : (ask :: (E, V) -> V)<(e :: E),a>) -> (std/core/hnd/clause0 :: (V, (E, V) -> V, E, V) -> V)<std/core/types/int,(ask :: (E, V) -> V),(e :: E),a>;
