val ask[72,12,72,14] : (std/core/types/@valueop :: (E, V) -> V)<<(std/core/types/handled1 :: ((E, V) -> V) -> X)<(ask :: (E, V) -> V)>>,std/core/types/int>;
fun ask-twice[74,5,74,13] : () -> <(std/core/types/handled1 :: ((E, V) -> V) -> X)<(ask :: (E, V) -> V)>> std/core/types/int;
pub fun example3[77,9,77,16] : () -> <(std/core/console/console :: X)> ();
