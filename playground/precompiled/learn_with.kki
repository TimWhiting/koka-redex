  };
fun example2 // inline size: 4
  = fn<<(std/core/console/console :: X)>>(){
    std/core/list/map<std/core/types/int,(),<(std/core/console/console :: X)>>((std/core/list/#range/list(1, 10)), (fn<<(std/core/console/console :: X)>>(x: std/core/types/int){
        (std/core/console/printsln((std/core/int/show(x))));
      }));
  };
