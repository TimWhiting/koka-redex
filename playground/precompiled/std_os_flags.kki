pub type flag-parser[137,1,144,54] <a> :: V -> V {
  // For a flag `foo` Automatically enables forms `--no-foo` and `--foo=true|false`.
  pub con Bool[140,3,140,6](default: (a, std/core/types/bool) -> a){0,1,8} : forall<a> (default : (a, std/core/types/bool) -> a) -> (flag-parser :: V -> V)<a> = 1;
  // A required argument.
  pub con Req[142,3,142,5](parse: (a, std/core/types/string) -> a, help: std/core/types/string){0,2,8} : forall<a> (parse : (a, std/core/types/string) -> a, help : std/core/types/string) -> (flag-parser :: V -> V)<a> = 2;
  // An optional argument.
  pub con Opt[144,3,144,5](parse: (a, (std/core/types/maybe :: V -> V)<std/core/types/string>) -> a, help: std/core/types/string){0,2,8} : forall<a> (parse : (a, (std/core/types/maybe :: V -> V)<std/core/types/string>) -> a, help : std/core/types/string) -> (flag-parser :: V -> V)<a> = 3;
};
