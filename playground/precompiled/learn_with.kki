// monadic lift
fun @mlift-twice@10060[1,0,1,0] : forall<a,(e :: E)> (f : () -> (e :: E) a, wild_ : a) -> (e :: E) a;
pub fun twice[20,9,20,13] : forall<a,(e :: E)> (f : () -> (e :: E) a) -> (e :: E) a;
pub fun example1[25,9,25,16] : () -> <(std/core/console/console :: X)> ();
// The above is equivalent to:
pub fun example1-expanded[31,9,31,25] : () -> <(std/core/console/console :: X)> ();
// Without using layout, the fully expanded version is:
pub fun example1-fully-expanded[38,9,38,31] : () -> <(std/core/console/console :: X)> ();
pub fun example2[58,9,58,16] : () -> <(std/core/console/console :: X)> (std/core/types/list :: V -> V)<()>;
// which is equivalent to:
pub fun example2-expanded[64,9,64,25] : () -> <(std/core/console/console :: X)> (std/core/types/list :: V -> V)<()>;
// select `@val-ask` operation out of effect `:ask`
fun @val-ask/@select[72,12,72,20] : forall<(e :: E),a> (^ hnd : (ask :: (E, V) -> V)<(e :: E),a>) -> (std/core/hnd/clause0 :: (V, (E, V) -> V, E, V) -> V)<std/core/types/int,(ask :: (E, V) -> V),(e :: E),a>;
// Call the `val ask` operation of the effect `:ask`
fun @val-ask[72,12,72,14] : () -> <(std/core/types/handled1 :: ((E, V) -> V) -> X)<(ask :: (E, V) -> V)>> std/core/types/int;
// Automatically generated. Retrieves the `@val-ask` constructor field of the `:ask` type.
fun ask/@val-ask[72,12,72,20] : forall<(e :: E),a> (^ ask : (ask :: (E, V) -> V)<(e :: E),a>) -> (std/core/hnd/clause0 :: (V, (E, V) -> V, E, V) -> V)<std/core/types/int,(ask :: (E, V) -> V),(e :: E),a>;
// Automatically generated. Retrieves the `@cfc` constructor field of the `:ask` type.
fun ask/@cfc[72,1,72,13] : forall<(e :: E),a> (^ ask : (ask :: (E, V) -> V)<(e :: E),a>) -> std/core/types/int;
// runtime tag for the effect `:ask`
val ask/@tag[72,1,72,13] : (std/core/hnd/htag :: ((E, V) -> V) -> V)<(ask :: (E, V) -> V)>;
// handler for the effect `:ask`
fun ask/@handle[72,12,72,13] : forall<a,(e :: E),b> (hnd : (ask :: (E, V) -> V)<(e :: E),b>, ret : (res : a) -> (e :: E) b, action : () -> <(std/core/types/handled1 :: ((E, V) -> V) -> X)<(ask :: (E, V) -> V)>|(e :: E)> a) -> (e :: E) b;
