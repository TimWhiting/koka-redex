inline borrow "^" fip fun is-binR // inline size: 1
  = forall<a,b> fn(zipper: (zipper :: (V, V) -> V)<a,b>){
    (match (zipper) {
      ((learn/fip/BinR((@pat@0: (tree :: V -> V)<b>) : (tree :: V -> V)<b>, (@pat@1: b) : b, (@pat@2: (zipper :: (V, V) -> V)<a,b>) : (zipper :: (V, V) -> V)<a,b>) : (zipper :: (V, V) -> V)<a,b> ) as @pat: ((zipper :: (V, V) -> V)<a,b>))
         -> std/core/types/True;
