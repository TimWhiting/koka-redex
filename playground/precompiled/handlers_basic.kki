  con @Hnd-raise[44,1,44,15](@cfc: std/core/types/int, @ctl-raise: forall<b> (std/core/hnd/clause1 :: (V, V, (E, V) -> V, E, V) -> V)<std/core/types/string,b,(raise :: (E, V) -> V),(e :: E),a>){0,2,8} : forall<(e :: E),a> (std/core/types/int, forall<b> (std/core/hnd/clause1 :: (V, V, (E, V) -> V, E, V) -> V)<std/core/types/string,b,(raise :: (E, V) -> V),(e :: E),a>) -> (raise :: (E, V) -> V)<(e :: E),a> = 1;
