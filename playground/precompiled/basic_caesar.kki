// Calculate how well two frequency tables match according
// to the _chi-square_ statistic.
fun chisqr[47,5,47,10] : (xs : (std/core/types/list :: V -> V)<std/core/types/float64>, ys : (std/core/types/list :: V -> V)<std/core/types/float64>) -> std/core/types/float64;
