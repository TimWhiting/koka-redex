borrow "_^" fip fun tmap // inline size: 1
  = forall<a,b,(e :: E)> fn<<(std/core/types/div :: X)|(e :: E)>>(t: (tree :: V -> V)<a>, f: (a) -> <(std/core/types/div :: X)|(e :: E)> b){
